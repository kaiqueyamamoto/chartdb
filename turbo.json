{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        "lint": {
            "outputs": []
        },
        "lint:fix": {
            "cache": false
        },
        "test:ci": {
            "outputs": ["coverage/**"]
        }
    }
}
